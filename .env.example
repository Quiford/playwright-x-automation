# TweeterTweet Replier — Environment Config
# All values are optional; sensible defaults are used when omitted.

# General
LOG_LEVEL=INFO
DATABASE_PATH=./engagement.db
REPLIES_JSON_PATH=./data/replies.json
ACCOUNTS_JSON_PATH=./data/accounts.json
MAX_ACCOUNTS=1000
MY_HANDLE=ElonMusk... ### Put your real handle here without the @ symbol. E.g ElonMusk, not @Elonmusk

# Active hours (JSON array of start/end objects in UTC 24h)
ACTIVE_HOURS=[] ## This translates to 24/7. For a more specific "on-time," use: [{"start": 9, "end": 22}] .... Which t translates to 9am to 10pm
INACTIVE_SLEEP_MINUTES=60



# Browser
BROWSER_HEADLESS=false
BROWSER_USER_DATA_DIR=./browser_profile
BROWSER_VIEWPORT_WIDTH=1280
BROWSER_VIEWPORT_HEIGHT=720
BROWSER_LOCALE=en-US
BROWSER_TIMEZONE=America/New_York

# Engagement behavior
ENGAGEMENT__REPLY_PROBABILITY=1.0 ## This translates to the bot replying all messages
ENGAGEMENT__MIN_DELAY_SECONDS=0
ENGAGEMENT__MAX_DELAY_SECONDS=0
ENGAGEMENT__DAILY_REPLY_LIMIT=100
ENGAGEMENT__VIEW_WITHOUT_REPLY_PROBABILITY=0.15
ENGAGEMENT__MUTATION_ENABLED=true
ENGAGEMENT__PER_ACCOUNT_COOLDOWN_MINUTES=30

# Optional proxy
PROXY_ENABLED=false ## Set to true if you want proxy enabled.
PROXY_SERVER=http://proxy.example.com:8080 ## Format is IP:PORT
PROXY_USERNAME=
PROXY_PASSWORD=

# Telegram notifications
TELEGRAM_ENABLED=false ## Set to true if you want telegram notifications.
TELEGRAM_BOT_TOKEN=your_bot_token_here
TELEGRAM_CHAT_ID=your_chat_id_here
